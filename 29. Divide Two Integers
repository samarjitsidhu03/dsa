class Solution {
public:
    int divide(int dividend, int divisor) {
        if (dividend == INT_MIN && divisor == -1) {
            return INT_MAX;
        }
        long long a = abs((long long)dividend);
        long long b = abs((long long)divisor);
        long long ans = 0;
        while (a >= b) {
            long long curr = b;
            long long count = 1;
            while ((curr << 1) <= a) {
                curr <<= 1;
                count <<= 1;
            }
            a -= curr;
            ans += count;
        }
        if ((dividend < 0) != (divisor < 0)) {
            ans = -ans;
        }

        return (int)ans;
    }
};
